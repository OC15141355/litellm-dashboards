      "title": "vs Previous Period",
      "type": "stat",
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH current_period AS (\n  SELECT COALESCE(SUM(spend), 0) AS spend\n  FROM \"LiteLLM_DailyTeamSpend\"\n  WHERE date::timestamp >= $__timeFrom()\n    AND date::timestamp <= $__timeTo()\n    AND team_id IN ($team)\n),\nprev_period AS (\n  SELECT COALESCE(SUM(spend), 0) AS spend\n  FROM \"LiteLLM_DailyTeamSpend\"\n  WHERE date::timestamp >= $__timeFrom()::timestamp - ($__timeTo()::timestamp - $__timeFrom()::timestamp)\n    AND date::timestamp < $__timeFrom()\n    AND team_id IN ($team)\n)\nSELECT\n  CASE WHEN p.spend > 0\n    THEN ROUND(((c.spend - p.spend) / p.spend * 100)::numeric, 1)\n    ELSE 0 END AS pct_change\nFROM current_period c, prev_period p",
          "refId": "A"
        }
      ]
    },
