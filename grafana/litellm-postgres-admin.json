          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  COALESCE(u.user_email, d.user_id, 'unknown') AS user,\n  SUM(d.spend) AS spend,\n  MAX(u.max_budget) AS budget,\n  CASE WHEN MAX(u.max_budget) > 0\n    THEN MAX(u.max_budget) - SUM(d.spend)\n    ELSE NULL END AS remaining,\n  CASE WHEN MAX(u.max_budget) > 0\n    THEN SUM(d.spend) / MAX(u.max_budget)\n    ELSE NULL END AS usage_pct,\n  SUM(d.api_requests) AS requests\nFROM \"LiteLLM_DailyUserSpend\" d\nLEFT JOIN \"LiteLLM_UserTable\" u ON d.user_id = u.user_id\nWHERE d.date::timestamp >= $__timeFrom()\n  AND d.date::timestamp <= $__timeTo()\n  AND d.api_key IN (\n    SELECT token FROM \"LiteLLM_VerificationToken\" WHERE team_id IN ($team)\n  )\nGROUP BY u.user_email, d.user_id\nORDER BY spend DESC",
          "refId": "A"
        }
      ]
