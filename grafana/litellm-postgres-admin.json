          "rawSql": "SELECT\n  CASE WHEN MAX(budget_reset_at) IS NOT NULL\n    THEN EXTRACT(EPOCH FROM MAX(budget_reset_at) - NOW()) / 86400.0\n    ELSE NULL END AS days_until_reset\nFROM \"LiteLLM_TeamTable\"\nWHERE team_id IN ($team)\n  AND budget_reset_at IS NOT NULL",
