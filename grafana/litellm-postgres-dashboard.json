              "rawSql": "SELECT\n  s.\"startTime\" AS time,\n  COALESCE(u.user_email, s.\"user\", 'unknown') AS user_email,\n  COALESCE(s.model_group, s.model) AS model,\n  s.spend,\n  s.prompt_tokens,\n  s.completion_tokens,\n  s.request_duration_ms AS duration_ms,\n  s.cache_hit,\n  s.status\nFROM \"LiteLLM_SpendLogs\" s\nLEFT JOIN \"LiteLLM_UserTable\" u ON s.\"user\" = u.user_id\nWHERE s.\"startTime\" >= $__timeFrom()\n  AND s.\"startTime\" <= $__timeTo()\n  AND ($team = 'all' OR s.team_id = '$team')\nORDER BY s.\"startTime\" DESC\nLIMIT 100",
