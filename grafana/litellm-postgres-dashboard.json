      "title": "Team Budget vs Actual",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "${datasource}" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  COALESCE(t.team_alias, 'unnamed') AS team,\n  t.max_budget AS budget,\n  COALESCE(SUM(d.spend), 0) AS spend,\n  CASE WHEN t.max_budget > 0\n    THEN COALESCE(SUM(d.spend), 0) / t.max_budget\n    ELSE 0 END AS usage_pct,\n  COALESCE(SUM(d.api_requests), 0) AS requests\nFROM \"LiteLLM_TeamTable\" t\nLEFT JOIN \"LiteLLM_DailyTeamSpend\" d\n  ON d.team_id = t.team_id\n  AND d.date::timestamp >= $__timeFrom()\n  AND d.date::timestamp <= $__timeTo()\nGROUP BY t.team_alias, t.max_budget\nORDER BY spend DESC",
          "refId": "A"
        }
      ]
