          "rawQuery": true,
          "rawSql": "SELECT\n  COALESCE(u.user_email, d.user_id, 'unknown') AS user_email,\n  d.user_id,\n  SUM(d.spend) AS spend,\n  SUM(d.api_requests) AS requests,\n  SUM(d.prompt_tokens) AS prompt_tokens,\n  SUM(d.completion_tokens) AS completion_tokens,\n  CASE WHEN SUM(d.api_requests) > 0\n    THEN SUM(d.spend) / SUM(d.api_requests)\n    ELSE 0 END AS avg_cost_per_req\nFROM \"LiteLLM_DailyUserSpend\" d\nLEFT JOIN \"LiteLLM_UserTable\" u ON d.user_id = u.user_id\nWHERE d.date::timestamp >= $__timeFrom()\n  AND d.date::timestamp <= $__timeTo()\n  AND ($team = 'all' OR d.api_key IN (\n    SELECT token FROM \"LiteLLM_VerificationToken\" WHERE team_id = '$team'\n  ))\nGROUP BY u.user_email, d.user_id\nORDER BY spend DESC",
