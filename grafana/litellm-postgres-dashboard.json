          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  COALESCE(t.team_alias, d.team_id, 'unassigned') AS team,\n  SUM(d.spend) AS spend\nFROM \"LiteLLM_DailyTeamSpend\" d\nLEFT JOIN \"LiteLLM_TeamTable\" t ON d.team_id = t.team_id\nWHERE d.date::timestamp >= $__timeFrom()\n  AND d.date::timestamp <= $__timeTo()\nGROUP BY COALESCE(t.team_alias, d.team_id, 'unassigned')\nORDER BY spend DESC",
